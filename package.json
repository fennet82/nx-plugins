{
  "name": "@fennet82/nx-plugins",
  "description": "A collection of third-party Nx plugins based (took inspo from https://github.com/nx-go/nx-go and https://github.com/berenddeboer/nx-plugins)",
  "author": {
    "name": "elad cohen"
  },
  "homepage": "https://github.com/fennet82/nx-plugins",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/plugin": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "~0.2.38",
    "@types/jest": "~30.0.0",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "commitlint": "^21.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "~30.4.2",
    "jest-environment-jsdom": "~30.4.1",
    "jest-util": "~30.4.1",
    "jiti": "2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "verdaccio": "6.7.4",
    "vite": "^8.1.0",
    "vitest": "~4.1.0"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
